{
  "name": "real-time-stock-dashboard",
  "private": true,
  "version": "1.0.0",
  "description": "Production-grade real-time stock dashboard monorepo",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w client",
    "start": "npm run start -w server",
    "lint": "npm run lint -w client && npm run lint -w server"
  },
  "engines": {
    "node": ">=20"
  }
}
